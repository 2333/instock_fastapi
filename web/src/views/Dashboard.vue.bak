<template>
  <div class="dashboard">
    <div class="dashboard-header">
      <div class="header-left">
        <h1>数据看板</h1>
        <p class="subtitle">市场概览与分析</p>
      </div>
      <div class="header-right">
        <span class="last-updated">更新时间: {{ lastUpdated }}</span>
        <button class="btn btn-primary" @click="refreshData">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8" />
            <path d="M21 3v5h-5" />
          </svg>
          刷新
        </button>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon market-up">📈</div>
        <div class="stat-content">
          <span class="stat-label">上证指数</span>
          <span class="stat-value price-up">{{ marketData.shanghai.toFixed(2) }}</span>
          <span class="stat-change price-up">+{{ shanghaiChange.toFixed(2) }}%</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon market-down">📉</div>
        <div class="stat-content">
          <span class="stat-label">深证成指</span>
          <span class="stat-value price-down">{{ marketData.shenzhen.toFixed(2) }}</span>
          <span class="stat-change price-down">{{ shenzhenChange.toFixed(2) }}%</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">💰</div>
        <div class="stat-content">
          <span class="stat-label">A股总数</span>
          <span class="stat-value">{{ marketData.totalStocks.toLocaleString() }}</span>
          <span class="stat-detail">交易中: {{ marketData.tradingStocks }}</span>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🔥</div>
        <div class="stat-content">
          <span class="stat-label">涨停</span>
          <span class="stat-value price-up">{{ marketData.limitUp }}</span>
          <span class="stat-detail">跌停: {{ marketData.limitDown }}</span>
        </div>
      </div>
    </div>

    <div class="dashboard-grid">
      <div class="card chart-card">
        <div class="card-header">
          <h3>市场趋势</h3>
          <div class="card-actions">
            <select v-model="selectedIndex" class="select-small">
              <option value="shanghai">上证指数</option>
              <option value="shenzhen">深证成指</option>
              <option value="创业板">创业板</option>
              <option value="科创50">科创50</option>
            </select>
          </div>
        </div>
        <div ref="marketChartRef" class="chart-wrapper"></div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>涨幅榜</h3>
          <router-link to="/stocks" class="card-link">查看全部</router-link>
        </div>
        <div class="stock-list">
          <div 
            v-for="stock in topGainers" 
            :key="stock.code"
            class="stock-item"
            @click="$router.push(`/stocks/${stock.code}`)"
          >
            <div class="stock-info">
              <span class="stock-code">{{ stock.code }}</span>
              <span class="stock-name">{{ stock.name }}</span>
            </div>
            <div class="stock-price">
              <span class="price">{{ stock.price.toFixed(2) }}</span>
              <span class="change price-up">+{{ stock.change.toFixed(2) }}%</span>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>跌幅榜</h3>
          <router-link to="/stocks" class="card-link">查看全部</router-link>
        </div>
        <div class="stock-list">
          <div 
            v-for="stock in topLosers" 
            :key="stock.code"
            class="stock-item"
            @click="$router.push(`/stocks/${stock.code}`)"
          >
            <div class="stock-info">
              <span class="stock-code">{{ stock.code }}</span>
              <span class="stock-name">{{ stock.name }}</span>
            </div>
            <div class="stock-price">
              <span class="price">{{ stock.price.toFixed(2) }}</span>
              <span class="change price-down">{{ stock.change.toFixed(2) }}%</span>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h3>今日形态</h3>
          <router-link to="/patterns" class="card-link">查看全部</router-link>
        </div>
        <div class="pattern-list">
          <div 
            v-for="pattern in recentPatterns" 
            :key="`${pattern.code}-${pattern.type}`"
            class="pattern-item"
            @click="$router.push(`/patterns?stock=${pattern.code}`)"
          >
            <div class="pattern-info">
              <span class="pattern-code">{{ pattern.code }}</span>
              <span class="pattern-name">{{ pattern.name }}</span>
            </div>
            <div class="pattern-meta">
              <span class="badge" :class="pattern.signal.toLowerCase()">{{ pattern.signal }}</span>
              <span class="pattern-confidence">{{ pattern.confidence }}%</span>
            </div>
          </div>
        </div>
      </div>

      <div class="card full-width">
        <div class="card-header">
          <h3>精选回顾</h3>
          <router-link to="/selection" class="card-link">查看全部</router-link>
        </div>
        <div class="selection-summary">
          <div class="selection-stat">
            <span class="selection-value">{{ selectionStats.total }}</span>
            <span class="selection-label">精选总数</span>
          </div>
          <div class="selection-stat">
            <span class="selection-value price-up">{{ selectionStats.winning }}</span>
            <span class="selection-label">盈利交易</span>
          </div>
          <div class="selection-stat">
            <span class="selection-value">{{ selectionStats.winRate }}%</span>
            <span class="selection-label">胜率</span>
          </div>
          <div class="selection-stat">
            <span class="selection-value">{{ selectionStats.avgReturn.toFixed(2) }}%</span>
            <span class="selection-label">平均收益</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref, reactive, computed, onMounted, shallowRef } from 'vue'
import { useResizeObserver } from '@vueuse/core'

interface StockItem {
  code: string
  name: string
  price: number
  change: number
}

interface PatternItem {
  code: string
  name: string
  type: string
  signal: string
  confidence: number
}

const marketChartRef = ref<HTMLDivElement>()
const marketChartInstance = shallowRef<any>(null)
const selectedIndex = ref('shanghai')
const lastUpdated = ref(new Date().toLocaleString())

const marketData = reactive({
  shanghai: 3245.67,
  shanghaiChange: 0.85,
  shenzhen: 1123.45,
  shenzhenChange: -0.32,
  totalStocks: 5348,
  tradingStocks: 4125,
  limitUp: 45,
  limitDown: 12,
})

const shanghaiChange = computed(() => marketData.shanghaiChange)
const shenzhenChange = computed(() => marketData.shenzhenChange)

const topGainers = ref<StockItem[]>([
  { code: '000863', name: '三湘印象', price: 5.68, change: 15.23 },
  { code: '002870', name: '香山股份', price: 23.45, change: 12.56 },
  { code: '300782', name: '卓胜微', price: 89.34, change: 11.23 },
  { code: '002625', name: '光启技术', price: 18.92, change: 10.45 },
  { code: '603259', name: '药明康德', price: 45.67, change: 9.87 },
])

const topLosers = ref<StockItem[]>([
  { code: '000504', name: '南华生物', price: 8.23, change: -12.34 },
  { code: '002868', name: '蓝博高', price: 12.34, change: -10.56 },
  { code: '300367', name: '网力科技', price: 4.56, change: -9.87 },
  { code: '000977', name: '浪潮信息', price: 18.90, change: -8.45 },
  { code: '600522', name: '中天科技', price: 15.67, change: -7.23 },
])

const recentPatterns = ref<PatternItem[]>([
  { code: '600519', name: '贵州茅台', type: 'Head & Shoulders', signal: 'BEARISH', confidence: 85 },
  { code: '000001', name: '平安银行', type: 'Double Bottom', signal: 'BULLISH', confidence: 78 },
  { code: '300750', name: '宁德时代', type: 'Bullish Flag', signal: 'BULLISH', confidence: 72 },
  { code: '002475', name: '立讯精密', type: 'Hammer', signal: 'BULLISH', confidence: 68 },
])

const selectionStats = reactive({
  total: 156,
  winning: 98,
  winRate: 62.8,
  avgReturn: 5.23,
})

const refreshData = () => {
  lastUpdated.value = new Date().toLocaleString()
  console.log('Refreshing dashboard data...')
}

const initMarketChart = async () => {
  if (!marketChartRef.value) return

  const echarts = (await import('echarts')).default
  marketChartInstance.value = echarts.init(marketChartRef.value, 'dark', {
    renderer: 'canvas',
  })

  const hours = Array.from({ length: 24 }, (_, i) => `${i.toString().padStart(2, '0')}:00`)
  const shanghaiData = [
    3200, 3210, 3215, 3220, 3225, 3230, 3228, 3232, 3235, 3240,
    3242, 3245, 3243, 3240, 3238, 3240, 3242, 3245, 3243, 3240,
    3238, 3240, 3235, 3230
  ]

  const option = {
    backgroundColor: 'transparent',
    tooltip: {
      trigger: 'axis',
      backgroundColor: 'rgba(26, 26, 26, 0.95)',
      borderColor: 'rgba(255, 255, 255, 0.1)',
      textStyle: { color: 'rgba(255, 255, 255, 0.9)' },
    },
    grid: { left: 50, right: 20, top: 20, bottom: 30 },
    xAxis: {
      type: 'category',
      data: hours,
      axisLine: { lineStyle: { color: 'rgba(255, 255, 255, 0.1)' } },
      axisLabel: { color: 'rgba(255, 255, 255, 0.5)', fontSize: 10 },
    },
    yAxis: {
      scale: true,
      axisLine: { lineStyle: { color: 'rgba(255, 255, 255, 0.1)' } },
      axisLabel: { color: 'rgba(255, 255, 255, 0.5)', fontSize: 10 },
      splitLine: { lineStyle: { color: 'rgba(255, 255, 255, 0.05)' } },
    },
    series: [{
      type: 'line',
      data: shanghaiData,
      smooth: true,
      lineStyle: { color: '#2962FF', width: 2 },
      areaStyle: {
        color: {
          type: 'linear',
          x: 0, y: 0, x2: 0, y2: 1,
          colorStops: [
            { offset: 0, color: 'rgba(41, 98, 255, 0.3)' },
            { offset: 1, color: 'rgba(41, 98, 255, 0)' },
          ],
        },
      },
    }],
  }

  marketChartInstance.value.setOption(option)

  useResizeObserver(marketChartRef, () => {
    marketChartInstance.value?.resize()
  })
}

onMounted(() => {
  initMarketChart()
})
</script>


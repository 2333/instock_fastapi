# InStock FastAPI 环境变量配置
# 复制此文件为 .env 并修改相应值

# ============ 数据库配置 ============
POSTGRES_PASSWORD=instock_pass
POSTGRES_USER=instock
POSTGRES_DB=instock

# ============ Redis 配置（可选） ============
# Compose 默认不再启动 Redis；需要启用缓存/分布式锁时再配置。
# REDIS_URL=redis://redis:6379/0
# REDIS_HOST=redis
# REDIS_PORT=6379

# ============ 预发布环境配置 ============
STAGING_POSTGRES_PORT=5434
STAGING_POSTGRES_PASSWORD=instock_pass
STAGING_POSTGRES_USER=instock
STAGING_POSTGRES_DB=instock
STAGING_APP_PORT=8002
STAGING_FRONTEND_PORT=3003
STAGING_SECRET_KEY=replace-with-at-least-32-chars-staging-secret
STAGING_LOG_LEVEL=INFO
STAGING_DEBUG=false
STAGING_SCHEDULER_ENABLED=false
STAGING_UVICORN_WORKERS=1

# ============ 应用配置 ============
APP_PORT=8000
APP_VERSION=0.2.0
APP_GIT_SHA=local
IMAGE_NAMESPACE=instock
DEBUG=false
UVICORN_WORKERS=1
SECRET_KEY=replace-with-at-least-32-chars-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ============ 外部服务 ============
# DATA_SOURCE_API_KEY=your-api-key
TUSHARE_TOKEN=replace-with-your-tushare-token
TUSHARE_HTTP_URL=http://lianghua.nanyangqiankun.top
INLINE_FALLBACK_ENABLED=false
FUND_FLOW_STOCK_SOURCE=eastmoney
FUND_FLOW_SECTOR_SOURCE=tushare
# PROXY_URL=http://proxy:7890
CRAWLER_PROXY_ENABLED=false
# CRAWLER_PROXY_FILE=/app/config/proxy.txt
DAILY_BAR_RETENTION_DAYS=3650
INDICATOR_RETENTION_DAYS=1095
PATTERN_RETENTION_DAYS=365
FUND_FLOW_RETENTION_DAYS=1095

# ============ 前端配置 ============
VITE_API_BASE_URL=http://localhost:8000/api/v1

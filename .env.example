# InStock FastAPI 环境变量配置
# 复制此文件为 .env 并修改相应值

# ============ 数据库配置 ============
POSTGRES_PASSWORD=instock_pass
POSTGRES_USER=instock
POSTGRES_DB=instock

# ============ Redis 配置 ============
REDIS_HOST=redis
REDIS_PORT=6379

# ============ 应用配置 ============
# API_SECRET_KEY=your-secret-key-here
# ALGORITHMS=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# CORS_ALLOW_ORIGINS=*
# CORS_ALLOW_CREDENTIALS=false
# CORS_ALLOW_METHODS=*
# CORS_ALLOW_HEADERS=*

# ============ 外部服务 ============
# DATA_SOURCE_API_KEY=your-api-key
# PROXY_URL=http://proxy:7890

# ============ 前端配置 ============
VITE_API_URL=http://localhost:8000
